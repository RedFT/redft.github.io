---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const wordCount = post.body ? post.body.trim().split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.round(wordCount / 200));

const allPosts = await getCollection('blog');
const otherPosts = allPosts
  .filter(p => p.id !== post.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const tags = post.data.tags || [];
---

<BaseLayout title={post.data.title} description={post.data.description} currentPath={Astro.url.pathname}>
  <a href="/" class="back-link">&larr; Back to all posts</a>
  <h1 class="post-title">{post.data.title}</h1>
  <p class="post-meta">
    <span class="post-date">{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
    <span class="separator">&middot;</span>
    <span class="reading-time">{readingTime} min read</span>
  </p>

  {
    tags.length > 0 && (
      <div class="post-tags">
        {tags.map(tag => (
          <a href={`/blog/tag/${tag}`} class="tag-pill">#{tag}</a>
        ))}
      </div>
    )
  }

  <Content />

  <div class="share-float">
    <a
      href={`https://www.reddit.com/submit?url=${encodeURIComponent(Astro.site + '/blog/' + post.id)}&title=${encodeURIComponent(post.data.title)}`}
      target="_blank"
      rel="noopener noreferrer"
      class="share-float-btn"
      aria-label="Share on Reddit"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.5 6.5a1.5 1.5 0 0 1 1.5 1.5 1.5 1.5 0 0 1-.65 1.22c.03.15.05.3.05.46 0 2.4-2.94 4.34-6.56 4.34S5.28 12.08 5.28 9.68c0-.15.02-.3.05-.46a1.5 1.5 0 1 1 1.37-2.49c.85-.55 2-.9 3.3-.94l.6-2.85a.3.3 0 0 1 .36-.24l2.02.43a1 1 0 1 1 .17.8l-1.56-.33-.57 2.7c1.25.07 2.36.42 3.18.95a1.48 1.48 0 0 1 1.32-.83zM8.57 11.2a1.1 1.1 0 0 0 0 2.2 1.1 1.1 0 0 0 0-2.2zm6.86 0a1.1 1.1 0 0 0 0 2.2 1.1 1.1 0 0 0 0-2.2zm-2.7 3.14a4.4 4.4 0 0 1 3.28 1.36.3.3 0 0 1-.44.42 3.8 3.8 0 0 0-2.84-1.14 3.8 3.8 0 0 0-2.84 1.14.3.3 0 0 1-.43-.42 4.4 4.4 0 0 1 3.27-1.36z"/></svg>
    </a>
    <a
      href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(Astro.site + '/blog/' + post.id)}`}
      target="_blank"
      rel="noopener noreferrer"
      class="share-float-btn"
      aria-label="Share on X"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
    </a>
    <a
      href={`https://news.ycombinator.com/submitlink?u=${encodeURIComponent(Astro.site + '/blog/' + post.id)}&t=${encodeURIComponent(post.data.title)}`}
      target="_blank"
      rel="noopener noreferrer"
      class="share-float-btn"
      aria-label="Share on Hacker News"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M6.951 5.896l4.112 7.708v5.064h1.974v-5.064l4.112-7.708h-2.22l-2.89 5.603-2.89-5.603H6.951z"/></svg>
    </a>
    <a
      href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.site + '/blog/' + post.id)}`}
      target="_blank"
      rel="noopener noreferrer"
      class="share-float-btn"
      aria-label="Share on LinkedIn"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
    </a>
    <a
      href={`https://bsky.app/intent/compose?text=${encodeURIComponent(post.data.title + ' ' + Astro.site + '/blog/' + post.id)}`}
      target="_blank"
      rel="noopener noreferrer"
      class="share-float-btn"
      aria-label="Share on Bluesky"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566 1.4 0 2.166 0 5.34c0 1.21.713 5.107.836 5.678C1.278 12.8 3.036 13.3 5.135 12.77 2.038 13.4 1.04 15.1 3.587 18.2c3.674 4.43 5.075-1.1 6.184-6.2.12-.55.223-1.02.329-1.39.106.37.21.84.33 1.39 1.109 5.1 2.51 10.63 6.184 6.2 2.548-3.1 1.55-4.8-1.548-5.43 2.099.53 3.857.03 4.299-1.252.123-.571.836-4.469.836-5.679 0-3.173-2.566-3.939-5.202-2.535C16.046 4.747 13.087 8.686 12 10.8z"/></svg>
    </a>
    <button class="share-float-btn" id="copy-link-btn" aria-label="Copy link">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
    </button>
  </div>

  {
    otherPosts.length > 0 && (
      <section class="suggested-posts">
        <h2>Continue reading</h2>
        <div class="suggested-grid">
          {otherPosts.map(suggested => (
            <a href={`/blog/${suggested.id}`} class="suggested-card">
              <h3>{suggested.data.title}</h3>
              {suggested.data.description && <p>{suggested.data.description}</p>}
            </a>
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>

<script>
  document.getElementById('copy-link-btn')?.addEventListener('click', function () {
    navigator.clipboard.writeText(window.location.href).then(() => {
      const orig = this.textContent;
      this.textContent = 'Copied!';
      setTimeout(() => { this.textContent = orig; }, 2000);
    });
  });
</script>
