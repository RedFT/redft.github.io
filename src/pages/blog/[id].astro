---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const wordCount = post.body ? post.body.trim().split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.round(wordCount / 200));

const allPosts = await getCollection('blog');
const otherPosts = allPosts
  .filter(p => p.id !== post.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const tags = post.data.tags || [];
---

<BaseLayout title={post.data.title} description={post.data.description} currentPath={Astro.url.pathname}>
  <a href="/" class="back-link">&larr; Back to all posts</a>
  <h1 class="post-title">{post.data.title}</h1>
  <p class="post-meta">
    <span class="post-date">{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
    <span class="separator">&middot;</span>
    <span class="reading-time">{readingTime} min read</span>
  </p>

  {
    tags.length > 0 && (
      <div class="post-tags">
        {tags.map(tag => (
          <a href={`/blog/tag/${tag}/`} class="tag-pill">#{tag}</a>
        ))}
      </div>
    )
  }

  <Content />

  {
    otherPosts.length > 0 && (
      <section class="suggested-posts">
        <h2>Continue reading</h2>
        <div class="suggested-grid">
          {otherPosts.map(suggested => (
            <a href={`/blog/${suggested.id}/`} class="suggested-card">
              <h3>{suggested.data.title}</h3>
              {suggested.data.description && <p>{suggested.data.description}</p>}
            </a>
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
