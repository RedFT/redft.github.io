---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const wordCount = post.body ? post.body.trim().split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.round(wordCount / 200));

const allPosts = await getCollection('blog');
const otherPosts = allPosts
  .filter(p => p.id !== post.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const tags = post.data.tags || [];
---

<BaseLayout title={post.data.title} description={post.data.description} currentPath={Astro.url.pathname}>
  <a href="/" class="back-link">&larr; Back to all posts</a>
  <h1 class="post-title">{post.data.title}</h1>
  <p class="post-meta">
    <span class="post-date">{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
    <span class="separator">&middot;</span>
    <span class="reading-time">{readingTime} min read</span>
  </p>

  {
    tags.length > 0 && (
      <div class="post-tags">
        {tags.map(tag => (
          <a href={`/blog/tag/${tag}`} class="tag-pill">#{tag}</a>
        ))}
      </div>
    )
  }

  <Content />

  <div class="share-float">
    <a
      href={`https://www.reddit.com/submit?url=${encodeURIComponent(Astro.site + '/blog/' + post.id)}&title=${encodeURIComponent(post.data.title)}`}
      target="_blank"
      rel="noopener noreferrer"
      class="share-float-btn"
      aria-label="Share on Reddit"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 3.314 1.343 6.314 3.515 8.485l-2.286 2.286C.775 23.225 1.097 24 1.738 24H12c6.627 0 12-5.373 12-12S18.627 0 12 0Zm4.388 3.199c1.104 0 1.999.895 1.999 1.999 0 1.105-.895 2-1.999 2-.946 0-1.739-.657-1.947-1.539v.002c-1.147.162-2.032 1.15-2.032 2.341v.007c1.776.067 3.4.567 4.686 1.363.473-.363 1.064-.58 1.707-.58 1.547 0 2.802 1.254 2.802 2.802 0 1.117-.655 2.081-1.601 2.531-.088 3.256-3.637 5.876-7.997 5.876-4.361 0-7.905-2.617-7.998-5.87-.954-.447-1.614-1.415-1.614-2.538 0-1.548 1.255-2.802 2.803-2.802.645 0 1.239.218 1.712.585 1.275-.79 2.881-1.291 4.64-1.365v-.01c0-1.663 1.263-3.034 2.88-3.207.188-.911.993-1.595 1.959-1.595Zm-8.085 8.376c-.784 0-1.459.78-1.506 1.797-.047 1.016.64 1.429 1.426 1.429.786 0 1.371-.369 1.418-1.385.047-1.017-.553-1.841-1.338-1.841Zm7.406 0c-.786 0-1.385.824-1.338 1.841.047 1.017.634 1.385 1.418 1.385.785 0 1.473-.413 1.426-1.429-.046-1.017-.721-1.797-1.506-1.797Zm-3.703 4.013c-.974 0-1.907.048-2.77.135-.147.015-.241.168-.183.305.483 1.154 1.622 1.964 2.953 1.964 1.33 0 2.47-.81 2.953-1.964.057-.137-.037-.29-.184-.305-.863-.087-1.795-.135-2.769-.135Z"/></svg>
    </a>
    <a
      href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(Astro.site + '/blog/' + post.id)}`}
      target="_blank"
      rel="noopener noreferrer"
      class="share-float-btn"
      aria-label="Share on X"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
    </a>
    <a
      href={`https://news.ycombinator.com/submitlink?u=${encodeURIComponent(Astro.site + '/blog/' + post.id)}&t=${encodeURIComponent(post.data.title)}`}
      target="_blank"
      rel="noopener noreferrer"
      class="share-float-btn"
      aria-label="Share on Hacker News"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M6.951 5.896l4.112 7.708v5.064h1.974v-5.064l4.112-7.708h-2.22l-2.89 5.603-2.89-5.603H6.951z"/></svg>
    </a>
    <a
      href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.site + '/blog/' + post.id)}`}
      target="_blank"
      rel="noopener noreferrer"
      class="share-float-btn"
      aria-label="Share on LinkedIn"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
    </a>
    <a
      href={`https://bsky.app/intent/compose?text=${encodeURIComponent(post.data.title + ' ' + Astro.site + '/blog/' + post.id)}`}
      target="_blank"
      rel="noopener noreferrer"
      class="share-float-btn"
      aria-label="Share on Bluesky"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M5.202 2.857C7.954 4.922 10.913 9.11 12 11.358c1.087-2.247 4.046-6.436 6.798-8.501C20.783 1.366 24 .213 24 3.883c0 .732-.42 6.156-.667 7.037-.856 3.061-3.978 3.842-6.755 3.37 4.854.826 6.089 3.562 3.422 6.299-5.065 5.196-7.28-1.304-7.847-2.97-.104-.305-.152-.448-.153-.327 0-.121-.05.022-.153.327-.568 1.666-2.782 8.166-7.847 2.97-2.667-2.737-1.432-5.473 3.422-6.3-2.777.473-5.899-.308-6.755-3.369C.42 10.04 0 4.615 0 3.883c0-3.67 3.217-2.517 5.202-1.026z"/></svg>
    </a>
    <button class="share-float-btn" id="copy-link-btn" aria-label="Copy link">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
    </button>
  </div>

  {
    otherPosts.length > 0 && (
      <section class="suggested-posts">
        <h2>Continue reading</h2>
        <div class="suggested-grid">
          {otherPosts.map(suggested => (
            <a href={`/blog/${suggested.id}`} class="suggested-card">
              <h3>{suggested.data.title}</h3>
              {suggested.data.description && <p>{suggested.data.description}</p>}
            </a>
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>

<script>
  document.getElementById('copy-link-btn')?.addEventListener('click', function () {
    navigator.clipboard.writeText(window.location.href).then(() => {
      const orig = this.textContent;
      this.textContent = 'Copied!';
      setTimeout(() => { this.textContent = orig; }, 2000);
    });
  });
</script>
