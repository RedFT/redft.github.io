---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const wordCount = post.body ? post.body.trim().split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.round(wordCount / 200));

const allPosts = await getCollection('blog');
const otherPosts = allPosts
  .filter(p => p.id !== post.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title={post.data.title} description={post.data.description} currentPath={Astro.url.pathname}>
  <a href="/" class="back-link">&larr; Back to all posts</a>
  <h1 class="post-title">{post.data.title}</h1>
  <p class="post-meta">
    <span class="post-date">{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
    <span class="separator">&middot;</span>
    <span class="reading-time">{readingTime} min read</span>
  </p>
  <Content />

  {
    otherPosts.length > 0 && (
      <section class="suggested-posts">
        <h2>Continue reading</h2>
        <div class="suggested-grid">
          {
            otherPosts.map(suggested => (
              <a href={`/blog/${suggested.id}/`} class="suggested-card">
                <h3>{suggested.data.title}</h3>
                {suggested.data.description && <p>{suggested.data.description}</p>}
              </a>
            ))
          }
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  .suggested-posts {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(232, 221, 208, 0.1);
  }

  .suggested-posts h2 {
    font-size: 1.1rem;
    font-weight: 600;
    color: #d97706;
    margin-bottom: 1.25rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .suggested-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1rem;
  }

  .suggested-card {
    display: block;
    padding: 1.25rem;
    background: rgba(232, 221, 208, 0.03);
    border: 1px solid rgba(232, 221, 208, 0.08);
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .suggested-card:hover {
    background: rgba(232, 221, 208, 0.06);
    border-color: rgba(232, 221, 208, 0.15);
  }

  .suggested-card h3 {
    font-size: 1rem;
    font-weight: 600;
    color: #e8ddd0;
    margin: 0 0 0.4rem 0;
    line-height: 1.3;
  }

  .suggested-card p {
    font-size: 0.85rem;
    color: rgba(232, 221, 208, 0.55);
    margin: 0;
    line-height: 1.4;
  }
</style>
